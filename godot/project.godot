; Minimal project used by the importer example and headless smoke tests.
; Keep this file compatible with the minimum supported Godot 4.3 API.
config_version=5

[application]

config/name="Mapsoo Worldsmith Godot Importer"
run/main_scene="res://example/main.tscn"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720

[editor_plugins]

enabled=PackedStringArray("res://addons/mapsoo_importer/plugin.cfg")

[rendering]

textures/default_filters/use_nearest_mipmap_filter=false
textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
