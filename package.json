{
  "name": "mapsoo-worldsmith",
  "version": "0.1.0-alpha.9",
  "private": false,
  "description": "Open-source world asset generator and Godot export pipeline.",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "stoyo:export": "node scripts/export-stoyo-pack.mjs",
    "stoyo:export:verify": "node scripts/verify-stoyo-export-cli.mjs",
    "workflow:verify": "node scripts/verify-workflow-yaml.mjs",
    "security:audit": "pnpm audit --audit-level high && pnpm --dir video audit --audit-level high",
    "third-party:write": "node scripts/verify-third-party-notices.mjs --write",
    "third-party:verify": "node scripts/verify-third-party-notices.mjs",
    "check": "pnpm release:version:verify && pnpm workflow:verify && pnpm typecheck && pnpm test && pnpm release:history:verify && pnpm release:receipt:negative && pnpm release:visuals:verify && pnpm third-party:verify && pnpm build",
    "release:version:verify": "node scripts/verify-release-version.mjs",
    "release:build": "node scripts/verify-release-version.mjs build && pnpm typecheck && pnpm third-party:verify && vite build --base / && node scripts/build-release.mjs",
    "release:verify": "node scripts/verify-release.mjs",
    "release:repro": "node scripts/check-release-reproducible.mjs",
    "release:local": "pnpm release:history:verify && pnpm release:receipt:negative && pnpm release:build && pnpm release:verify && pnpm release:repro",
    "release:pack:hash": "node scripts/hash-example-pack.mjs",
    "fixture:capture:alpha2": "node scripts/capture-alpha2-example-pack.mjs",
    "fixture:capture:alpha3": "node scripts/capture-alpha3-example-pack.mjs",
    "fixture:capture:alpha4": "node scripts/capture-alpha4-example-pack.mjs",
    "fixture:capture:alpha5": "node scripts/capture-alpha5-example-pack.mjs",
    "fixture:capture:alpha6": "node scripts/capture-alpha6-example-pack.mjs",
    "release:history:verify": "node scripts/verify-release-history.mjs",
    "release:history:remote": "node scripts/verify-public-release-assets.mjs",
    "release:receipt:negative": "node scripts/test-receipt-verifier-negative.mjs",
    "release:browser:verify": "node scripts/verify-browser-alpha2-export.mjs && node scripts/verify-browser-alpha3-export.mjs && node scripts/verify-browser-alpha3-export.mjs --version=0.1.0-alpha.4 && node scripts/verify-browser-alpha3-export.mjs --version=0.1.0-alpha.5 && node scripts/verify-browser-alpha3-export.mjs --version=0.1.0-alpha.6 && node scripts/verify-browser-alpha7-export.mjs && pnpm stoyo:export:verify",
    "fixture:browser:alpha2": "node scripts/verify-browser-alpha2-export.mjs --capture=release/browser-captures/mapsoo-sunny-meadow-v0.1.0-alpha.2.zip",
    "fixture:browser:alpha3": "node scripts/verify-browser-alpha3-export.mjs --capture=release/browser-captures/mapsoo-sunny-meadow-v0.1.0-alpha.3.zip",
    "fixture:browser:alpha4": "node scripts/verify-browser-alpha3-export.mjs --version=0.1.0-alpha.4 --capture=release/browser-captures/mapsoo-sunny-meadow-v0.1.0-alpha.4.zip",
    "fixture:browser:alpha5": "node scripts/verify-browser-alpha3-export.mjs --version=0.1.0-alpha.5 --capture=release/browser-captures/mapsoo-sunny-meadow-v0.1.0-alpha.5.zip",
    "fixture:browser:alpha6": "node scripts/verify-browser-alpha3-export.mjs --version=0.1.0-alpha.6 --capture=release/browser-captures/mapsoo-sunny-meadow-v0.1.0-alpha.6.zip",
    "fixture:browser:alpha7": "node scripts/verify-browser-alpha7-export.mjs --capture && node scripts/capture-alpha7-example-packs.mjs",
    "release:visuals:verify": "node scripts/verify-release-visuals.mjs",
    "release:itch:source:verify": "node scripts/verify-itch-source.mjs",
    "release:itch:build": "node scripts/build-itch-kit.mjs",
    "release:itch:verify": "node scripts/verify-itch-kit.mjs",
    "release:itch:repro": "node scripts/check-itch-kit-reproducible.mjs",
    "release:itch:negative": "node scripts/test-itch-kit-negative.mjs",
    "release:itch": "pnpm release:history:verify && pnpm release:receipt:negative && pnpm release:itch:source:verify && pnpm release:itch:build && pnpm release:itch:verify && pnpm release:itch:repro && pnpm release:itch:negative"
  },
  "dependencies": {
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "jszip": "3.10.1",
    "pako": "1.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "typescript": "^5.8.3",
    "vite": "6.4.3",
    "vitest": "^3.2.4",
    "yaml": "2.8.1"
  }
}
