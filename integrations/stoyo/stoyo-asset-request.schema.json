{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mapsoo.dev/integrations/stoyo/stoyo-asset-request-1.0.0.json",
  "title": "STOYO Asset Request",
  "description": "A privacy-minimized, allowlisted request for projecting caller-supplied public-safe STOYO scene values into a Mapsoo World Spec.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "packId", "world", "scene", "seed", "visual", "map", "output"],
  "properties": {
    "schemaVersion": { "const": "dev.stoyo.asset-request/1.0.0" },
    "packId": { "$ref": "#/$defs/id" },
    "world": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "title", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "version": {
          "type": "string",
          "maxLength": 80,
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z]+(?:[.-][0-9A-Za-z]+)*)?$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F]*\\S[^\\u0000-\\u001F\\u007F-\\u009F]*$"
        },
        "description": {
          "type": "string",
          "maxLength": 1000,
          "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F]*$"
        }
      }
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "requiredSceneTags", "contentRating"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "requiredSceneTags": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "contentRating": { "$ref": "#/$defs/id" }
      }
    },
    "seed": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F]*\\S[^\\u0000-\\u001F\\u007F-\\u009F]*$"
    },
    "visual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["style", "tileSize", "palette"],
      "properties": {
        "style": { "const": "pixel-art" },
        "tileSize": { "enum": [16, 32, 64] },
        "palette": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
        }
      }
    },
    "map": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "biome"],
      "properties": {
        "width": { "type": "integer", "minimum": 8, "maximum": 48 },
        "height": { "type": "integer", "minimum": 8, "maximum": 32 },
        "biome": { "enum": ["meadow", "desert", "snow"] }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targets", "assetLicense"],
      "properties": {
        "targets": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "prefixItems": [
            { "const": "common" },
            { "const": "godot" },
            { "const": "itch" }
          ],
          "items": false
        },
        "assetLicense": { "const": "CC0-1.0" }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  }
}
