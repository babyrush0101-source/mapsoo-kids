{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mapsoo.dev/schemas/mapsoo-side-platformer-scene-0.2.0.json",
  "title": "Mapsoo Side-platformer Scene 0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile", "completeness_policy", "bounds", "spawn", "layers", "placements"],
  "properties": {
    "schema_version": { "const": "0.2.0" },
    "profile": { "const": "side-platformer" },
    "completeness_policy": { "const": "side-platformer-complete-v1" },
    "bounds": { "$ref": "#/$defs/rect" },
    "spawn": { "$ref": "#/$defs/point" },
    "layers": { "const": ["background-far", "background-mid", "background-near", "world", "foreground"] },
    "placements": { "type": "array", "minItems": 1, "maxItems": 4096, "items": { "$ref": "#/$defs/placement" } }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "maxLength": 80, "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$" },
    "point": { "type": "object", "additionalProperties": false, "required": ["x", "y"], "properties": { "x": { "type": "integer", "minimum": 0, "maximum": 8191 }, "y": { "type": "integer", "minimum": 0, "maximum": 8191 } } },
    "rect": { "type": "object", "additionalProperties": false, "required": ["x", "y", "width", "height"], "properties": { "x": { "type": "integer", "minimum": 0, "maximum": 8191 }, "y": { "type": "integer", "minimum": 0, "maximum": 8191 }, "width": { "type": "integer", "minimum": 1, "maximum": 8192 }, "height": { "type": "integer", "minimum": 1, "maximum": 8192 } } },
    "placement": { "type": "object", "additionalProperties": false, "required": ["id", "role", "layer", "x", "y"], "properties": { "id": { "$ref": "#/$defs/id" }, "role": { "type": "string", "minLength": 1, "maxLength": 80 }, "layer": { "enum": ["background-far", "background-mid", "background-near", "world", "foreground"] }, "x": { "type": "integer", "minimum": 0, "maximum": 8191 }, "y": { "type": "integer", "minimum": 0, "maximum": 8191 }, "flip_x": { "type": "boolean" } } }
  }
}
