{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mapsoo.dev/schemas/mapsoo-pack-0.7.0.json",
  "title": "Mapsoo Complete Side-platformer Pack Manifest 0.7",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "pack", "profile", "completeness_policy", "compatibility", "layers", "atlases", "roles", "character", "runtime", "files", "license", "provenance"],
  "properties": {
    "schema_version": { "const": "0.7.0" },
    "pack": { "type": "object", "additionalProperties": false, "required": ["id", "title", "version", "generator", "created_at"], "properties": { "id": { "$ref": "#/$defs/id" }, "title": { "$ref": "#/$defs/text" }, "version": { "const": "0.1.0-alpha.10" }, "generator": { "const": { "name": "Mapsoo Worldsmith", "version": "0.1.0-alpha.10" } }, "created_at": { "type": "string", "format": "date-time" } } },
    "profile": { "const": "side-platformer" }, "completeness_policy": { "const": "side-platformer-complete-v1" },
    "compatibility": { "const": { "godot_min": "4.3", "grid": "pixel", "art_style": "pixel_art", "importer": { "id": "mapsoo_importer", "min_version": "0.1.0-alpha.10" } } },
    "layers": { "const": [{"id":"background-far","order":0},{"id":"background-mid","order":1},{"id":"background-near","order":2},{"id":"world","order":3},{"id":"foreground","order":4}] },
    "atlases": { "type": "array", "minItems": 8, "maxItems": 8, "prefixItems": [
      {"$ref":"#/$defs/atlasTerrain"},{"$ref":"#/$defs/atlasHazards"},{"$ref":"#/$defs/atlasProps"},{"$ref":"#/$defs/atlasStructures"},{"$ref":"#/$defs/atlasCollectibles"},{"$ref":"#/$defs/atlasBackgrounds"},{"$ref":"#/$defs/atlasForeground"},{"$ref":"#/$defs/atlasCharacter"}
    ], "items": false },
    "roles": { "type": "array", "minItems": 30, "maxItems": 30, "prefixItems": [
      {"$ref":"#/$defs/r01"},{"$ref":"#/$defs/r02"},{"$ref":"#/$defs/r03"},{"$ref":"#/$defs/r04"},{"$ref":"#/$defs/r05"},{"$ref":"#/$defs/r06"},{"$ref":"#/$defs/r07"},{"$ref":"#/$defs/r08"},{"$ref":"#/$defs/r09"},{"$ref":"#/$defs/r10"},
      {"$ref":"#/$defs/r11"},{"$ref":"#/$defs/r12"},{"$ref":"#/$defs/r13"},{"$ref":"#/$defs/r14"},{"$ref":"#/$defs/r15"},{"$ref":"#/$defs/r16"},{"$ref":"#/$defs/r17"},{"$ref":"#/$defs/r18"},{"$ref":"#/$defs/r19"},{"$ref":"#/$defs/r20"},
      {"$ref":"#/$defs/r21"},{"$ref":"#/$defs/r22"},{"$ref":"#/$defs/r23"},{"$ref":"#/$defs/r24"},{"$ref":"#/$defs/r25"},{"$ref":"#/$defs/r26"},{"$ref":"#/$defs/r27"},{"$ref":"#/$defs/r28"},{"$ref":"#/$defs/r29"},{"$ref":"#/$defs/r30"}
    ], "items": false },
    "character": { "type": "object", "additionalProperties": false, "required": ["id","atlas","frame_size","pivot","clips"], "properties": { "id":{"$ref":"#/$defs/id"}, "atlas":{"$ref":"#/$defs/path"}, "frame_size":{"$ref":"#/$defs/positivePair"}, "pivot":{"$ref":"#/$defs/numberPair"}, "clips": { "type":"array","minItems":12,"maxItems":12,"prefixItems":[
      {"$ref":"#/$defs/c01"},{"$ref":"#/$defs/c02"},{"$ref":"#/$defs/c03"},{"$ref":"#/$defs/c04"},{"$ref":"#/$defs/c05"},{"$ref":"#/$defs/c06"},{"$ref":"#/$defs/c07"},{"$ref":"#/$defs/c08"},{"$ref":"#/$defs/c09"},{"$ref":"#/$defs/c10"},{"$ref":"#/$defs/c11"},{"$ref":"#/$defs/c12"}
    ],"items":false} } },
    "runtime": { "type":"object","additionalProperties":false,"required":["scene","collision","navigation","spawn"],"properties":{"scene":{"$ref":"#/$defs/pathObject"},"collision":{"$ref":"#/$defs/pathObject"},"navigation":{"$ref":"#/$defs/pathObject"},"spawn":{"$ref":"#/$defs/point"}} },
    "files": { "type":"array","minItems":1,"maxItems":512,"items":{"$ref":"#/$defs/file"} },
    "license": { "type":"object","additionalProperties":false,"required":["output"],"properties":{"output":{"type":"object","additionalProperties":false,"required":["id","notice_path","permits_redistribution"],"properties":{"id":{"$ref":"#/$defs/text"},"notice_path":{"$ref":"#/$defs/path"},"permits_redistribution":{"const":true}}}} },
    "provenance": { "type":"object","additionalProperties":false,"required":["provider","output_provenance","contains_generative_ai","model_provider","model","seed","human_curated"],"properties":{"provider":{"type":"object","additionalProperties":false,"required":["id","version"],"properties":{"id":{"$ref":"#/$defs/id"},"version":{"$ref":"#/$defs/text"}}},"output_provenance":{"enum":["procedural","generative-ai","hybrid"]},"contains_generative_ai":{"type":"boolean"},"model_provider":{"type":["string","null"],"minLength":1,"maxLength":160},"model":{"type":["string","null"],"minLength":1,"maxLength":160},"seed":{"$ref":"#/$defs/text"},"human_curated":{"type":"boolean"}} }
  },
  "$defs": {
    "id":{"type":"string","minLength":1,"maxLength":80,"pattern":"^[a-z0-9]+(?:[-_][a-z0-9]+)*$"}, "text":{"type":"string","minLength":1,"maxLength":160,"pattern":"^.*\\S.*$"},
    "path":{"type":"string","minLength":1,"maxLength":240,"pattern":"^(?!/)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*\\\\)[A-Za-z0-9][A-Za-z0-9._+!#$&^~-]*(?:/[A-Za-z0-9][A-Za-z0-9._+!#$&^~-]*)*$"},
    "point":{"type":"object","additionalProperties":false,"required":["x","y"],"properties":{"x":{"type":"integer","minimum":0,"maximum":8191},"y":{"type":"integer","minimum":0,"maximum":8191}}},
    "positivePair":{"type":"array","minItems":2,"maxItems":2,"items":{"type":"integer","minimum":1,"maximum":8192}}, "numberPair":{"type":"array","minItems":2,"maxItems":2,"items":{"type":"number","minimum":-8192,"maximum":8192}},
    "pathObject":{"type":"object","additionalProperties":false,"required":["path"],"properties":{"path":{"$ref":"#/$defs/path"}}},
    "atlas":{"type":"object","additionalProperties":false,"required":["id","path"],"properties":{"id":{"type":"string"},"path":{"$ref":"#/$defs/path"}}},
    "atlasTerrain":{"allOf":[{"$ref":"#/$defs/atlas"},{"properties":{"id":{"const":"terrain"}}}]}, "atlasHazards":{"allOf":[{"$ref":"#/$defs/atlas"},{"properties":{"id":{"const":"hazards"}}}]}, "atlasProps":{"allOf":[{"$ref":"#/$defs/atlas"},{"properties":{"id":{"const":"props"}}}]}, "atlasStructures":{"allOf":[{"$ref":"#/$defs/atlas"},{"properties":{"id":{"const":"structures"}}}]}, "atlasCollectibles":{"allOf":[{"$ref":"#/$defs/atlas"},{"properties":{"id":{"const":"collectibles"}}}]}, "atlasBackgrounds":{"allOf":[{"$ref":"#/$defs/atlas"},{"properties":{"id":{"const":"backgrounds"}}}]}, "atlasForeground":{"allOf":[{"$ref":"#/$defs/atlas"},{"properties":{"id":{"const":"foreground"}}}]}, "atlasCharacter":{"allOf":[{"$ref":"#/$defs/atlas"},{"properties":{"id":{"const":"character"}}}]},
    "role":{"type":"object","additionalProperties":false,"required":["role","path"],"properties":{"role":{"type":"string"},"path":{"$ref":"#/$defs/path"}}},
    "r01":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"terrain.solid"}}}]},"r02":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"terrain.one-way"}}}]},"r03":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"terrain.slope-up"}}}]},"r04":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"terrain.slope-down"}}}]},"r05":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"terrain.wall"}}}]},"r06":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"terrain.ceiling"}}}]},
    "r07":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"hazard.spikes"}}}]},"r08":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"hazard.pit"}}}]},"r09":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"hazard.moving-platform"}}}]},
    "r10":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"prop.crate"}}}]},"r11":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"prop.rock"}}}]},"r12":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"prop.plant"}}}]},"r13":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"prop.sign"}}}]},"r14":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"prop.lamp"}}}]},"r15":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"prop.breakable"}}}]},
    "r16":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"structure.entrance"}}}]},"r17":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"structure.exit"}}}]},"r18":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"structure.checkpoint"}}}]},"r19":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"collectible.primary"}}}]},"r20":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"collectible.health"}}}]},
    "r21":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"background.sky"}}}]},"r22":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"background.far"}}}]},"r23":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"background.mid"}}}]},"r24":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"background.near"}}}]},"r25":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"foreground.overlay"}}}]},"r26":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"character.player.atlas"}}}]},"r27":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"world.collision"}}}]},"r28":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"world.navigation"}}}]},"r29":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"world.scene"}}}]},"r30":{"allOf":[{"$ref":"#/$defs/role"},{"properties":{"role":{"const":"world.preview"}}}]},
    "frame":{"type":"object","additionalProperties":false,"required":["x","y"],"properties":{"x":{"type":"integer","minimum":0,"maximum":8191},"y":{"type":"integer","minimum":0,"maximum":8191}}},
    "clip":{"type":"object","additionalProperties":false,"required":["id","action","direction","fps","frames"],"properties":{"id":{"type":"string"},"action":{"enum":["idle","run","jump","fall","land","hurt"]},"direction":{"enum":["left","right"]},"fps":{"type":"number","exclusiveMinimum":0,"maximum":60},"frames":{"type":"array","minItems":1,"maxItems":32,"items":{"$ref":"#/$defs/frame"}}}},
    "c01":{"allOf":[{"$ref":"#/$defs/clip"},{"properties":{"id":{"const":"idle.left"},"action":{"const":"idle"},"direction":{"const":"left"}}}]},"c02":{"allOf":[{"$ref":"#/$defs/clip"},{"properties":{"id":{"const":"idle.right"},"action":{"const":"idle"},"direction":{"const":"right"}}}]},"c03":{"allOf":[{"$ref":"#/$defs/clip"},{"properties":{"id":{"const":"run.left"},"action":{"const":"run"},"direction":{"const":"left"}}}]},"c04":{"allOf":[{"$ref":"#/$defs/clip"},{"properties":{"id":{"const":"run.right"},"action":{"const":"run"},"direction":{"const":"right"}}}]},"c05":{"allOf":[{"$ref":"#/$defs/clip"},{"properties":{"id":{"const":"jump.left"},"action":{"const":"jump"},"direction":{"const":"left"}}}]},"c06":{"allOf":[{"$ref":"#/$defs/clip"},{"properties":{"id":{"const":"jump.right"},"action":{"const":"jump"},"direction":{"const":"right"}}}]},"c07":{"allOf":[{"$ref":"#/$defs/clip"},{"properties":{"id":{"const":"fall.left"},"action":{"const":"fall"},"direction":{"const":"left"}}}]},"c08":{"allOf":[{"$ref":"#/$defs/clip"},{"properties":{"id":{"const":"fall.right"},"action":{"const":"fall"},"direction":{"const":"right"}}}]},"c09":{"allOf":[{"$ref":"#/$defs/clip"},{"properties":{"id":{"const":"land.left"},"action":{"const":"land"},"direction":{"const":"left"}}}]},"c10":{"allOf":[{"$ref":"#/$defs/clip"},{"properties":{"id":{"const":"land.right"},"action":{"const":"land"},"direction":{"const":"right"}}}]},"c11":{"allOf":[{"$ref":"#/$defs/clip"},{"properties":{"id":{"const":"hurt.left"},"action":{"const":"hurt"},"direction":{"const":"left"}}}]},"c12":{"allOf":[{"$ref":"#/$defs/clip"},{"properties":{"id":{"const":"hurt.right"},"action":{"const":"hurt"},"direction":{"const":"right"}}}]},
    "file":{"type":"object","additionalProperties":false,"required":["path","media_type","bytes","sha256"],"properties":{"path":{"$ref":"#/$defs/path"},"media_type":{"enum":["image/png","application/json","application/schema+json","text/markdown"]},"bytes":{"type":"integer","minimum":1,"maximum":9007199254740991},"sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"}}}
  }
}
