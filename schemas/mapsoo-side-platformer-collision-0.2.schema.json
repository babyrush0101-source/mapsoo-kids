{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mapsoo.dev/schemas/mapsoo-side-platformer-collision-0.2.0.json",
  "title": "Mapsoo Side-platformer Collision 0.2",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "profile", "completeness_policy", "bounds", "spawn", "surfaces", "hazards"],
  "properties": {
    "schema_version": { "const": "0.2.0" }, "profile": { "const": "side-platformer" }, "completeness_policy": { "const": "side-platformer-complete-v1" },
    "bounds": { "$ref": "#/$defs/rect" }, "spawn": { "$ref": "#/$defs/point" },
    "surfaces": { "type": "array", "minItems": 1, "maxItems": 2048, "items": { "type": "object", "additionalProperties": false, "required": ["id", "kind", "rect"], "properties": { "id": { "$ref": "#/$defs/id" }, "kind": { "enum": ["solid", "one-way"] }, "rect": { "$ref": "#/$defs/rect" } } } },
    "hazards": { "type": "array", "maxItems": 1024, "items": { "type": "object", "additionalProperties": false, "required": ["id", "kind", "rect"], "properties": { "id": { "$ref": "#/$defs/id" }, "kind": { "enum": ["spikes", "pit"] }, "rect": { "$ref": "#/$defs/rect" } } } }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "maxLength": 80, "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$" },
    "point": { "type": "object", "additionalProperties": false, "required": ["x", "y"], "properties": { "x": { "type": "integer", "minimum": 0, "maximum": 8191 }, "y": { "type": "integer", "minimum": 0, "maximum": 8191 } } },
    "rect": { "type": "object", "additionalProperties": false, "required": ["x", "y", "width", "height"], "properties": { "x": { "type": "integer", "minimum": 0, "maximum": 8191 }, "y": { "type": "integer", "minimum": 0, "maximum": 8191 }, "width": { "type": "integer", "minimum": 1, "maximum": 8192 }, "height": { "type": "integer", "minimum": 1, "maximum": 8192 } } }
  }
}
