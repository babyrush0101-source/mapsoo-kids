              "const": "crop.basic.stage-4"
            }
          }
        }
      ]
    },
    "roleCharacter": {
      "allOf": [
        {
          "$ref": "#/$defs/role"
        },
        {
          "properties": {
            "role": {
              "const": "character.player.atlas"
            }
          }
        }
      ]
    },
    "roleCollision": {
      "allOf": [
        {
          "$ref": "#/$defs/role"
        },
        {
          "properties": {
            "role": {
              "const": "world.collision"
            }
          }
        }
      ]
    },
    "roleNavigation": {
      "allOf": [
        {
          "$ref": "#/$defs/role"
        },
        {
          "properties": {
            "role": {
              "const": "world.navigation"
            }
          }
        }
      ]
    },
    "roleScene": {
      "allOf": [
        {
          "$ref": "#/$defs/role"
        },
        {
          "properties": {
            "role": {
              "const": "world.scene"
            }
          }
        }
      ]
    },
    "rolePreview": {
      "allOf": [
        {
          "$ref": "#/$defs/role"
        },
        {
          "properties": {
            "role": {
              "const": "world.preview"
            }
          }
        }
      ]
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8191
        },
        "y": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8191
        }
      }
    },
    "clip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "action",
        "direction",
        "fps",
        "frames"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "action": {
          "enum": [
            "idle",
            "walk"
          ]
        },
        "direction": {
          "enum": [
            "north",
            "east",
            "south",
            "west"
          ]
        },
        "fps": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 60
        },
        "frames": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/frame"
          }
        }
      }
    },
    "idleNorth": {
      "allOf": [
        {
          "$ref": "#/$defs/clip"
        },
        {
          "properties": {
            "id": {
              "const": "idle.north"
            },
            "action": {
              "const": "idle"
            },
            "direction": {
              "const": "north"
            }
          }
        }
      ]
    },
    "idleEast": {
      "allOf": [
        {
          "$ref": "#/$defs/clip"
        },
        {
          "properties": {
            "id": {
              "const": "idle.east"
            },
            "action": {
              "const": "idle"
            },
            "direction": {
              "const": "east"
            }
          }
        }
      ]
    },
    "idleSouth": {
      "allOf": [
        {
          "$ref": "#/$defs/clip"
        },
        {
          "properties": {
            "id": {
              "const": "idle.south"
            },
            "action": {
              "const": "idle"
            },
            "direction": {
              "const": "south"
            }
          }
        }
      ]
    },
    "idleWest": {
      "allOf": [
        {
          "$ref": "#/$defs/clip"
        },
        {
          "properties": {
            "id": {
              "const": "idle.west"
            },
            "action": {
              "const": "idle"
            },
            "direction": {
              "const": "west"
            }
          }
        }
      ]
    },
    "walkNorth": {
      "allOf": [
        {
          "$ref": "#/$defs/clip"
        },
        {
          "properties": {
            "id": {
              "const": "walk.north"
            },
            "action": {
              "const": "walk"
            },
            "direction": {
              "const": "north"
            }
          }
        }
      ]
    },
    "walkEast": {
      "allOf": [
        {
          "$ref": "#/$defs/clip"
        },
        {
          "properties": {
            "id": {
              "const": "walk.east"
            },
            "action": {
              "const": "walk"
            },
            "direction": {
              "const": "east"
            }
          }
        }
      ]
    },
    "walkSouth": {
      "allOf": [
        {
          "$ref": "#/$defs/clip"
        },
        {
          "properties": {
            "id": {
              "const": "walk.south"
            },
            "action": {
              "const": "walk"
            },
            "direction": {
              "const": "south"
            }
          }
        }
      ]
    },
    "walkWest": {
      "allOf": [
        {
          "$ref": "#/$defs/clip"
        },
        {
          "properties": {
            "id": {
              "const": "walk.west"
            },
            "action": {
              "const": "walk"
            },
            "direction": {
              "const": "west"
            }
          }
        }
      ]
    },
    "fileRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "media_type",
        "bytes",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/path"
        },
        "media_type": {
          "enum": [
            "image/png",
            "application/json",
            "application/schema+json",
            "text/markdown"
          ]
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
