{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mapsoo.dev/schemas/mapsoo-world-0.3.0.json",
  "title": "Mapsoo World Spec 0.3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "description",
    "seed",
    "visual",
    "map",
    "output"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.3.0"
    },
    "id": {
      "$ref": "#/$defs/slug80"
    },
    "title": {
      "$ref": "#/$defs/trimmed120"
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    },
    "seed": {
      "$ref": "#/$defs/trimmed160"
    },
    "visual": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "style",
        "tileSize",
        "palette"
      ],
      "properties": {
        "style": {
          "const": "pixel-art"
        },
        "tileSize": {
          "enum": [
            16,
            32,
            64
          ]
        },
        "palette": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          }
        }
      }
    },
    "map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "biome"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 8,
          "maximum": 48
        },
        "height": {
          "type": "integer",
          "minimum": 8,
          "maximum": 32
        },
        "biome": {
          "enum": [
            "meadow",
            "desert",
            "snow"
          ]
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targets",
        "assetLicense"
      ],
      "properties": {
        "targets": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "prefixItems": [
            {
              "const": "common"
            },
            {
              "const": "godot"
            },
            {
              "const": "itch"
            }
          ],
          "items": false
        },
        "assetLicense": {
          "const": "CC0-1.0"
        }
      }
    },
    "places": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/place"
      }
    },
    "structures": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/structure"
      }
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z0-9]+)+$"
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "slug80": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "trimmed120": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[^\\s\\u0000-\\u001F\\u007F-\\u009F](?:[^\\u0000-\\u001F\\u007F-\\u009F]*[^\\s\\u0000-\\u001F\\u007F-\\u009F])?$"
    },
    "trimmed160": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\\s\\u0000-\\u001F\\u007F-\\u009F](?:[^\\u0000-\\u001F\\u007F-\\u009F]*[^\\s\\u0000-\\u001F\\u007F-\\u009F])?$"
    },
    "place": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "kind",
        "placement",
        "tags"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/slug64"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^[^\\s\\u0000-\\u001F\\u007F-\\u009F](?:[^\\u0000-\\u001F\\u007F-\\u009F]*[^\\s\\u0000-\\u001F\\u007F-\\u009F])?$"
        },
        "kind": {
          "enum": [
            "spawn",
            "settlement",
            "landmark",
            "resource",
            "encounter",
            "exit"
          ]
        },
        "placement": {
          "enum": [
            "center",
            "near-water",
            "on-road",
            "map-edge"
          ]
        },
        "tags": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 32,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        }
      }
    },
    "structure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "placeId",
        "archetype"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/slug64"
        },
        "placeId": {
          "$ref": "#/$defs/slug64"
        },
        "archetype": {
          "enum": [
            "cottage",
            "workshop",
            "tower",
            "shrine"
          ]
        }
      }
    },
    "slug64": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  }
}
