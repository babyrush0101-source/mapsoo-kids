{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mapsoo.dev/schemas/mapsoo-world-0.1.0.json",
  "title": "Mapsoo World Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "description",
    "seed",
    "visual",
    "map",
    "output"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1.0"
    },
    "id": {
      "type": "string",
      "maxLength": 80,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F]*\\S[^\\u0000-\\u001F\\u007F-\\u009F]*$"
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    },
    "seed": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F]*\\S[^\\u0000-\\u001F\\u007F-\\u009F]*$"
    },
    "visual": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "style",
        "tileSize",
        "palette"
      ],
      "properties": {
        "style": {
          "const": "pixel-art"
        },
        "tileSize": {
          "enum": [
            16,
            32,
            64
          ]
        },
        "palette": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          }
        }
      }
    },
    "map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "biome"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 8,
          "maximum": 48
        },
        "height": {
          "type": "integer",
          "minimum": 8,
          "maximum": 32
        },
        "biome": {
          "enum": [
            "meadow",
            "desert",
            "snow"
          ]
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targets",
        "assetLicense"
      ],
      "properties": {
        "targets": {
          "type": "array",
          "prefixItems": [
            {
              "const": "common"
            },
            {
              "const": "godot"
            },
            {
              "const": "itch"
            }
          ],
          "items": false
        },
        "assetLicense": {
          "const": "CC0-1.0"
        }
      }
    },
    "extensions": {
      "type": "object",
      "description": "Namespaced integration metadata. Keys should use reverse-DNS notation, for example dev.stoyo.",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z0-9]+)+$"
      },
      "additionalProperties": true
    }
  }
}
